{
  "tasks": {
    "dev": "deno run --watch main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "name": "@axhxrx/utf8-stream-occurrences",
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  },
  "exclude": [
    ".claude",
    ".git",
    ".github",
    ".vscode",
    "CLAUDE.md",
    "bun.lock",
    "dprint.jsonc",
    "node_modules",
    "tsconfig.json",
    "**/*.test.ts",
    "*.examples.ts"
  ]
}
