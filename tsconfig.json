{
  "compilerOptions": {
    // Environment setup & latest features
    // "lib": ["ESNext"],
    // NOTE: The presence of "lib" will break `deno check` in the "ejected monorepo subproject"
    // context (e.g. this project, when not located in a parent monorepo), because if present,
    // Deno will try to respect it, overriding its defaults. Bun is not bothered if "lib" is missing.
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
